# Copy to .env and fill in. Never commit .env.
# Required
ROBOFLOW_API_KEY=your_roboflow_private_api_key

# Optional: default workspace slug so tools don't need it every call
ROBOFLOW_WORKSPACE=

# Optional: override the API base if you proxy Roboflow
ROBOFLOW_API_URL=https://api.roboflow.com

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
ROBOFLOW_MCP_LOG_LEVEL=INFO
